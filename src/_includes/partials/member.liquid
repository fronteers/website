<div data-partial="member" class="member">
    <header class="member-header member-header-{{ index }}">
        {%- if member.data.graphic -%}
            <img src="{{ member.data.graphic.src }}"alt="{%- if member.data.graphic.alt -%}{{ member.data.graphic.alt }}{%- endif -%}"class="member-graphic" />
        {%- endif -%}
        <a href="{{ member.url }}" class="member-name">
            {%- include partials/utility/dynamic-headerlevel level: "h3" title: member.data.title -%}
        </a>
    </header>
</div>
